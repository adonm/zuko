# frozen_string_literal: true
# Pin fastlane so CI uses a reproducible version instead of whatever
# Homebrew bottled most recently. Silences the "Get started using a Gemfile
# for fastlane" banner and the "fastlane X.Y.Z is available — please update"
# nag from the runner's pre-installed gem.
#
# CI invokes lanes via `bundle exec fastlane …` (see
# .github/workflows/release-ios.yml). Local dev can do the same after
# `bundle install` — or keep using `fastlane …` directly against the brew
# install; the Fastfile is pure-ruby and runs under either.

source "https://rubygems.org"

gem "fastlane", "~> 2.236"
# xcodeproj is what we use to patch signing in the Fastfile's `archive`
# lane; pin it explicitly so a fastlane dependency reshuffle can't break
# the build silently. fastlane already ships it transitively.
gem "xcodeproj", "~> 1.27"
