# frozen_string_literal: true
#
# fastlane lanes for Zuko. Invoke from `ios/` (or anywhere below it — fastlane
# will find the Fastfile via the `fastlane/` directory):
#
#   fastlane build   # generate project + build a signed .ipa (App Store method)
#   fastlane beta    # build + upload to TestFlight
#
# Signing material lives in GitHub secrets on this repo (no separate match
# repo). The CI workflow imports the .p12 into a keychain and installs the
# provisioning profile *before* invoking fastlane, so the lanes below assume a
# working keychain + profile. See ios/DISTRIBUTION.md.

APP_IDENTIFIER = "dev.adonm.zuko"

# Anchor paths against the Fastfile's own location: fastlane chdirs into
# `fastlane/` when running a lane (see runner.rb's chdir around lane
# execution), so relative paths would resolve against `fastlane/` and miss
# `Zuko/` and `Zuko/Zuko.xcodeproj` next door. `__dir__` is this Fastfile's
# directory; one level up is `ios/`.
IOS_DIR = File.expand_path("..", __dir__)
XCODEPROJ = File.join(IOS_DIR, "Zuko", "Zuko.xcodeproj")
PROJECT_SPEC = File.join(IOS_DIR, "Zuko", "project.yml")

default_platform(:ios)

# App Store Connect API key for TestFlight upload (assembled from secrets).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_CONTENT"),
    in_house: false,
    duration: 1_200
  )
end

platform :ios do
  desc "Generate the Xcode project and build a signed .ipa (App Store method)"
  private_lane :archive do
    sh("xcodegen generate --spec '#{PROJECT_SPEC}'")

    # Signing: the project defaults to automatic signing (good for local dev),
    # but CI has only an App Store (distribution) profile installed — no
    # development profile, no Apple ID logged into Xcode. In CI (detected via
    # $APP_PROFILE_UUID, surfaced by release-ios.yml's profile-install step)
    # we switch the Zuko target to manual signing driven by the imported cert
    # + profile. Local dev skips this block and keeps automatic signing.
    #
    # The override is applied to the Zuko TARGET ONLY, not via xcargs. Setting
    # CODE_SIGN_STYLE / PROVISIONING_PROFILE project-wide (the only scope
    # xcargs supports) propagates to SwiftPM dependency targets like SwiftTerm,
    # which doesn't support provisioning profiles and errors out with
    # "SwiftTerm_SwiftTerm does not support provisioning profiles". The
    # `xcodeproj` gem ships with fastlane, so no extra dependency.
    if ENV["APP_PROFILE_UUID"]
      UI.message("CI: switching Zuko target to manual signing (profile UUID #{ENV.fetch('APP_PROFILE_UUID')})")
      require "xcodeproj"
      project = Xcodeproj::Project.open(XCODEPROJ)
      target = project.targets.find { |t| t.name == "Zuko" }
      UI.user_error!("Could not find target 'Zuko' in #{XCODEPROJ}") unless target
      # `target.build_settings` in xcodeproj 1.x is a method taking a config
      # name, NOT a hash — set per-configuration via `build_configurations`
      # (each entry's `build_settings` IS a mutable hash). Apply to every
      # config (Release + Debug + anything else) so the archive (Release) and
      # any ad-hoc builds both pick up the override.
      target.build_configurations.each do |config|
        config.build_settings["CODE_SIGN_STYLE"] = "Manual"
        # xcodebuild prefix-matches the identity name, so "Apple Distribution"
        # hits the cert's full name ("Apple Distribution: <Name> (<TeamID>)").
        config.build_settings["CODE_SIGN_IDENTITY"] = "Apple Distribution"
        config.build_settings["PROVISIONING_PROFILE"] = ENV.fetch("APP_PROFILE_UUID")
        config.build_settings["DEVELOPMENT_TEAM"] = ENV.fetch("TEAM_ID", "")
        config.build_settings["CODE_SIGNING_REQUIRED"] = "YES"
      end
      project.save
    end

    gym(
      project: XCODEPROJ,
      scheme: "Zuko",
      clean: true,
      export_method: "app-store",
      # Only the safe, project-wide settings go through xcargs now — the
      # target-specific signing bits were written into the pbxproj above.
      xcargs: {
        "DEVELOPMENT_TEAM" => ENV.fetch("TEAM_ID", ""),
        "CODE_SIGNING_REQUIRED" => "YES",
      }
    )
  end

  desc "Build a signed .ipa (App Store method); publish as a workflow artifact"
  lane :build do
    archive
  end

  desc "Build a signed .ipa and upload to TestFlight"
  lane :beta do
    archive
    # NOTE: the app must exist in App Store Connect before this works.
    # Create it once manually: appstoreconnect.apple.com → My Apps → + →
    # New App (name: Zuko, bundle ID: dev.adonm.zuko). `produce` can't
    # automate this because it requires Apple ID username/password auth
    # (not API key) in fastlane 2.236.x.
    upload_to_testflight(
      api_key: asc_api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
