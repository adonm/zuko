# macOS
.DS_Store

# Xcode
build/
DerivedData/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
xcuserdata/
*.xcodeproj/
*.xcworkspace/

# SwiftPM
.build/
Package.resolved
.swiftpm/

# Generated by XcodeGen — project.yml is the source of truth
ios/Zuko/Zuko.xcodeproj/

# Built/generated by xtool (`mise run build-ios`).
ios/xtool/

# Built by scripts/build-ffi.sh — the Rust staticlib wrapped as an XCFramework.
# Regenerate with `mise run build-ios` (or `mise run build-ffi` directly).
# The Swift bindings (Sources/ZukoFFI/ZukoFFI.swift) ARE committed (deterministic).
ios/ZukoFFI/ZukoRust.xcframework/
ios/ZukoFFI/Generated/

# Rust / host
target/
**/*.rs.bk

# Local secrets / runtime state
*.key
zuko-key

# Apple signing material produced by `mise run setup-ios-signing`. Default
# workspace is outside the repo (~/.config/zuko/ios-signing), but gitignore
# these anyway in case someone overrides ZUKO_IOS_SIGNING_DIR into the tree.
*.p12
*.cer
*.mobileprovision
*.p8
p12-password
team-id
asc-key-id
asc-issuer-id
