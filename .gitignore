# macOS
.DS_Store

# Xcode
build/
DerivedData/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
xcuserdata/
*.xcodeproj/
*.xcworkspace/

# Flutter's Apple runners are committed source.
!flutter/ios/Runner.xcodeproj/
!flutter/ios/Runner.xcodeproj/**
!flutter/ios/Runner.xcworkspace/
!flutter/ios/Runner.xcworkspace/**
!flutter/macos/Runner.xcodeproj/
!flutter/macos/Runner.xcodeproj/**
!flutter/macos/Runner.xcworkspace/
!flutter/macos/Runner.xcworkspace/**

# SwiftPM
.build/
Package.resolved
.swiftpm/

# Rust / host
target/
dist/
**/*.rs.bk
__pycache__/
.tmp/

# Android signing (the Flutter tree has its own generated-file ignores).
*.jks
*.keystore
keystore-password
key-password

# Flutter web's generated Iroh bridge.
flutter/web/wasm/

# lychee link-checker cache (mise run lint-md)
.lycheecache

# Local secrets / runtime state
*.key
zuko-key

# Local TestFlight feedback archives (downloaded from ASC for review).
# Keep them out of the tree — they're session artifacts, not source.
testflight_feedback.zip
testflight_feedback/

# Local review/audit reports produced by `oy` (`oy-review`, `oy audit`).
# Same rationale: session artifacts surfaced in chat, not source.
REVIEW.md
ISSUES.md

# Apple signing material produced by `mise run setup-ios-signing`. Default
# workspace is outside the repo (~/.config/zuko/ios-signing), but gitignore
# these anyway in case someone overrides ZUKO_IOS_SIGNING_DIR into the tree.
*.p12
*.cer
*.mobileprovision
*.p8
p12-password
team-id
asc-key-id
asc-issuer-id
